# Copy this file to .env and uncomment only the values you need.
# Never commit private keys, mnemonics, API keys, or other secrets.
# No environment variables are required for install, compile, lint, or tests.

# Required when sending transactions to Celo or Celo Sepolia. Not required for
# read-only commands or the built-in simulated Hardhat network.
# PRIVATE_KEY=0x...

# Required only for Celoscan verification. Leave unset when verification is not
# needed or when Sourcify alone is sufficient.
# CELOSCAN_API_KEY=

# Optional localhost overrides. Defaults: http://127.0.0.1:8545 and the
# repository's public development mnemonic.
# LOCALHOST_RPC_URL=http://127.0.0.1:8545
# LOCALHOST_MNEMONIC=

# Optional override for the Hardhat Ignition project directory. Default: ./ignition.
# IGNITION_ROOT=ignition

# Optional source revision recorded in deployment manifests outside CI. CI uses
# GITHUB_SHA automatically.
# SOURCE_REVISION=<git-commit-sha>

# Required only when submitting a Safe owner-action transaction with
# owner:submit or safe:propose. It is not required for status checks.
# SAFE_PROPOSER_PRIVATE_KEY=0x...

# Optional Safe Transaction Service overrides. SAFE_API_KEY is needed only when
# the selected service requires authentication; the URL is normally chain-derived.
# SAFE_API_KEY=
# SAFE_TX_SERVICE_URL=

# Optional Solidity fuzz and invariant overrides. The values below are the defaults.
# CONTRACT_FUZZ_RUNS=256
# CONTRACT_FUZZ_SEED=0x4242424242424242424242424242424242424242424242424242424242424242
# CONTRACT_INVARIANT_RUNS=64
# CONTRACT_INVARIANT_DEPTH=50

# Optional opt-in for the slow ten-year scale test.
# RUN_SCALE_TESTS=1

# Optional Slither runner overrides. The values below are the defaults.
# SLITHER_SOLC=solc
# SLITHER_SOURCE=git+https://github.com/crytic/slither.git@master
