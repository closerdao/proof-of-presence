{
  "compilerOptions": {
    "target": "es2022",
    "module": "node16",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "hardhat.config.ts",
    "./scripts",
    "./ignition",
    "./test"
  ],
  "exclude": ["node_modules", "dist", "artifacts", "cache"]
}
