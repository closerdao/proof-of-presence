{
  "name": "proof-of-presence",
  "version": "0.1.0",
  "type": "module",
  "description": "Closer village access, community token, and tokenized-stay smart contracts.",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.19.0"
  },
  "repository": "github:closerdao/proof-of-presence",
  "author": "Closer Dao",
  "license": "MIT",
  "keywords": [
    "ethereum",
    "smart-contracts",
    "celo",
    "hardhat",
    "solidity"
  ],
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@nomicfoundation/hardhat-ethers": "4.0.15",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "3.0.11",
    "@nomicfoundation/hardhat-ignition": "3.1.8",
    "@nomicfoundation/hardhat-ignition-ethers": "3.1.6",
    "@nomicfoundation/hardhat-mocha": "3.0.21",
    "@nomicfoundation/hardhat-verify": "3.0.21",
    "@nomicfoundation/ignition-core": "3.1.8",
    "@openzeppelin/contracts": "5.6.1",
    "@openzeppelin/contracts-upgradeable": "5.6.1",
    "@openzeppelin/hardhat-upgrades": "4.0.2",
    "@safe-global/api-kit": "5.0.1",
    "@safe-global/protocol-kit": "8.0.4",
    "@safe-global/types-kit": "4.0.1",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "22.20.1",
    "chai": "5.3.3",
    "dotenv": "16.6.1",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "ethers": "6.17.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "3.11.0",
    "mocha": "11.7.6",
    "prettier": "3.9.5",
    "prettier-plugin-solidity": "2.3.1",
    "solhint": "6.2.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "zod": "4.4.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts}\" && yarn lint:solidity",
    "lint:fix": "eslint --fix \"**/*.{js,ts}\" && yarn lint:solidity:fix",
    "lint:solidity": "solhint --max-warnings 0 --disc --noPoster \"src/village/**/*.sol\" \"src/profiles/tdf/**/*.sol\"",
    "lint:solidity:fix": "solhint --fix --disc --noPoster \"src/village/**/*.sol\" \"src/profiles/tdf/**/*.sol\"",
    "format": "prettier --check \"**/*.{ts,js,sol}\"",
    "format:fix": "prettier --write \"**/*.{ts,js,sol}\"",
    "compile": "hardhat compile",
    "test": "yarn test:solidity && yarn test:typescript",
    "test:solidity": "hardhat test solidity",
    "test:typescript": "hardhat test mocha",
    "test:deep": "CONTRACT_FUZZ_RUNS=2000 CONTRACT_INVARIANT_RUNS=256 CONTRACT_INVARIANT_DEPTH=100 hardhat test solidity",
    "test:gambit-mutants": "node scripts/security/test-gambit-mutants.js",
    "test:scale": "hardhat test mocha test/village/scale/TokenizedStays.scale.test.ts",
    "validate:upgrades": "hardhat compile --force && tsx scripts/validate-upgrades.ts",
    "analyze:aderyn": "node scripts/security/run-aderyn.js",
    "analyze:gambit": "node scripts/security/run-gambit.js",
    "analyze:wake": "node scripts/security/run-wake.js",
    "analyze:slither": "node scripts/security/run-slither.js",
    "analyze:standards": "node scripts/security/run-slither-standards.js",
    "analyze:smt": "node scripts/security/run-smt.js",
    "security:dependencies": "node scripts/security/run-osv.js",
    "security:dependencies:update": "node scripts/security/run-osv.js --update",
    "security:artifacts": "hardhat compile --force && node scripts/security/check-artifacts.js",
    "security:artifacts:update": "hardhat compile --force && node scripts/security/check-artifacts.js --update",
    "security:coverage": "yarn coverage && node scripts/security/check-coverage.js",
    "security:coverage:update": "node scripts/security/check-coverage.js --update",
    "coverage": "CONTRACT_FUZZ_RUNS=32 CONTRACT_INVARIANT_RUNS=8 CONTRACT_INVARIANT_DEPTH=20 hardhat test solidity --coverage",
    "dev:node": "hardhat node --hostname 0.0.0.0",
    "deploy": "node ./scripts/print-deploy-help.js",
    "deploy:contract": "tsx scripts/deploy-contract.ts",
    "deploy:village": "tsx scripts/deploy-village.ts",
    "deploy:tdf": "tsx scripts/deploy-village.ts --profile tdf",
    "owner:submit": "tsx scripts/propose-safe-transaction.ts",
    "owner:status": "tsx scripts/check-safe-transaction.ts",
    "safe:propose": "tsx scripts/propose-safe-transaction.ts",
    "safe:status": "tsx scripts/check-safe-transaction.ts",
    "upgrade:prepare": "tsx scripts/prepare-upgrade.ts",
    "verify:village": "tsx scripts/verify-village.ts",
    "export:village": "tsx scripts/export-village.ts",
    "hardhat": "hardhat"
  }
}
