{
  "name": "proof-of-presence",
  "version": "0.1.0",
  "type": "module",
  "description": "Collection of contracts aiming to implement tokenized timeshare access to land projects.",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.19.0"
  },
  "repository": "github:closerdao/proof-of-presence",
  "author": "Closer Dao",
  "license": "MIT",
  "keywords": [
    "ethereum",
    "smart-contracts",
    "boilerplate",
    "hardhat",
    "solidity"
  ],
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@nomicfoundation/hardhat-ethers": "4.0.15",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "3.0.11",
    "@nomicfoundation/hardhat-ignition": "3.1.8",
    "@nomicfoundation/hardhat-ignition-ethers": "3.1.6",
    "@nomicfoundation/hardhat-mocha": "3.0.21",
    "@nomicfoundation/hardhat-network-helpers": "3.0.11",
    "@nomicfoundation/hardhat-typechain": "3.1.1",
    "@nomicfoundation/hardhat-verify": "3.0.21",
    "@nomicfoundation/ignition-core": "3.1.8",
    "@openzeppelin/contracts": "5.6.1",
    "@openzeppelin/contracts-v4": "npm:@openzeppelin/contracts@4.7.2",
    "@openzeppelin/hardhat-upgrades": "4.0.2",
    "@rocketh/deploy": "0.19.1",
    "@rocketh/diamond": "0.19.1",
    "@rocketh/node": "0.19.3",
    "@rocketh/proxy": "0.19.4",
    "@rocketh/read-execute": "0.19.0",
    "@safe-global/api-kit": "5.0.1",
    "@safe-global/protocol-kit": "8.0.4",
    "@safe-global/safe-deployments": "1.37.60",
    "@safe-global/types-kit": "4.0.1",
    "@typechain/ethers-v6": "0.5.1",
    "@types/chai": "5.2.3",
    "@types/fs-extra": "9.0.13",
    "@types/luxon": "3.0.1",
    "@types/mocha": "10.0.10",
    "@types/node": "22.19.13",
    "chai": "5.3.3",
    "dotenv": "16.0.0",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "ethers": "6.17.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "fs-extra": "10.1.0",
    "hardhat": "3.10.0",
    "hardhat-deploy": "2.0.1",
    "luxon": "3.0.4",
    "mocha": "11.7.6",
    "prettier": "3.9.5",
    "prettier-plugin-solidity": "2.3.1",
    "rocketh": "0.19.3",
    "solhint": "6.2.3",
    "tsx": "4.23.1",
    "typechain": "8.3.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "zod": "4.4.3"
  },
  "scripts": {
    "prepare": "node ./.setup.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts}\" && yarn lint:solidity",
    "lint:fix": "eslint --fix \"**/*.{js,ts}\" && yarn lint:solidity:fix",
    "lint:solidity": "solhint --max-warnings 0 --disc --noPoster \"src/village/**/*.sol\" \"src/profiles/tdf-v2/**/*.sol\"",
    "lint:solidity:fix": "solhint --fix --disc --noPoster \"src/village/**/*.sol\" \"src/profiles/tdf-v2/**/*.sol\"",
    "format": "prettier --check \"**/*.{ts,js,sol}\"",
    "format:fix": "prettier --write \"**/*.{ts,js,sol}\"",
    "compile": "hardhat compile && tsx scripts/merge-diamond-abi.ts",
    "void:deploy": "node ./scripts/print-deploy-help.js",
    "test": "hardhat test",
    "test:v2": "yarn test:v2:solidity && yarn test:v2:typescript",
    "test:v2:solidity": "hardhat test solidity",
    "test:v2:typescript": "hardhat test mocha --grep \"^V2\"",
    "test:v2:deep": "V2_FUZZ_RUNS=2000 V2_INVARIANT_RUNS=256 V2_INVARIANT_DEPTH=100 hardhat test solidity",
    "test:v2:scale": "RUN_V2_SCALE=1 hardhat test mocha test/village/scale/TokenizedStays.scale.test.ts",
    "validate:upgrades": "hardhat compile --force && tsx scripts/validate-upgrades.ts",
    "analyze:aderyn": "node scripts/security/run-aderyn.js",
    "analyze:wake": "node scripts/security/run-wake.js",
    "analyze:slither": "node scripts/security/run-slither.js",
    "analyze:standards": "node scripts/security/run-slither-standards.js",
    "analyze:smt": "node scripts/security/run-smt.js",
    "security:dependencies": "node scripts/security/run-osv.js",
    "security:dependencies:update": "node scripts/security/run-osv.js --update",
    "security:artifacts": "hardhat compile --force && node scripts/security/check-artifacts.js",
    "security:artifacts:update": "hardhat compile --force && node scripts/security/check-artifacts.js --update",
    "security:coverage": "yarn coverage:v2 && node scripts/security/check-coverage.js",
    "security:coverage:update": "node scripts/security/check-coverage.js --update",
    "coverage": "hardhat test --coverage",
    "coverage:v2": "V2_FUZZ_RUNS=32 V2_INVARIANT_RUNS=8 V2_INVARIANT_DEPTH=20 hardhat test solidity --coverage",
    "dev:node": "hardhat node --hostname 0.0.0.0",
    "execute": "node ./_scripts.cjs run",
    "deploy": "node ./scripts/print-deploy-help.js",
    "deploy:legacy": "node ./_scripts.cjs deploy:legacy",
    "deploy:contract": "tsx scripts/deploy-contract.ts",
    "deploy:village": "tsx scripts/deploy-village.ts",
    "deploy:tdf-v2": "tsx scripts/deploy-village.ts --profile tdf-v2",
    "owner:submit": "tsx scripts/propose-safe-transaction.ts",
    "owner:status": "tsx scripts/check-safe-transaction.ts",
    "safe:propose": "tsx scripts/propose-safe-transaction.ts",
    "safe:status": "tsx scripts/check-safe-transaction.ts",
    "upgrade:v2:prepare": "tsx scripts/prepare-v2-upgrade.ts",
    "verify:legacy": "node ./_scripts.cjs verify:legacy",
    "verify:village": "tsx scripts/verify-village.ts",
    "export:village": "tsx scripts/export-village.ts",
    "hardhat": "hardhat",
    "fork:execute": "node ./_scripts.cjs fork:run",
    "fork:deploy": "node ./_scripts.cjs fork:deploy",
    "fork:dev": "node ./_scripts.cjs fork:dev",
    "fork:node": "node ./_scripts.cjs fork:node",
    "fork:test": "node ./_scripts.cjs fork:test",
    "tenderly:push": "node ./_scripts.cjs tenderly:push",
    "commit": "npx git-cz"
  },
  "dependencies": {
    "@openzeppelin/contracts-upgradeable": "5.6.1",
    "@openzeppelin/contracts-upgradeable-v4": "npm:@openzeppelin/contracts-upgradeable@4.8.0-rc.1",
    "@types/lodash": "4.17.24",
    "date-fns": "2.28.0",
    "lodash": "4.18.1"
  }
}
